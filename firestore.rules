rules_version = '2';

// OshiHub Firestore セキュリティルール（β版）
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザードキュメント: 本人のみ読み書き可
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // 参戦記録（推し活Wrapped 集計元）: 本人のみ
      match /attendance/{eventId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // イベント / ニュース: 公開情報のため誰でも読み取り可（SEO公開ページ・未ログイン閲覧のため）。
    // 書き込みは AI 収集バックエンド（Admin SDK / サーバー）に限定するため、
    // クライアントからの write は禁止。
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }
    match /news/{newsId} {
      allow read: if true;
      allow write: if false;
    }

    // 公開ファンランキング: 誰でも閲覧可、自分の行のみ書き込み可。
    match /leaderboard/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // グループ別ランキング（docId: "{groupId}__{uid}"）: 公開読み取り、本人のみ書き込み。
    match /groupRanking/{docId} {
      allow read: if true;
      allow write: if request.auth != null && docId.split('__')[1] == request.auth.uid;
    }

    // 月別ランキング（docId: "{month}__{group}__{uid}"）: 公開読み取り、本人のみ書き込み。
    match /monthlyRanking/{docId} {
      allow read: if true;
      allow write: if request.auth != null && docId.split('__')[2] == request.auth.uid;
    }

    // リマインド送信済みマーカー: サーバー(Admin SDK)専用。クライアントからは不可。
    match /reminderLog/{id} {
      allow read, write: if false;
    }
  }
}
